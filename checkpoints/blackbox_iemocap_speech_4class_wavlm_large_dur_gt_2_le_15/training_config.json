{
  "input_dim": 2048,
  "feature_extractor_name": "microsoft/wavlm-large",
  "encoder_embedding_dim": 1024,
  "pooling": "mean_std",
  "hidden_dims": [
    256,
    128
  ],
  "num_classes": 4,
  "dropout": 0.25,
  "activation": "gelu",
  "batch_size": 64,
  "epochs": 100,
  "learning_rate": 0.0002,
  "weight_decay": 0.0005,
  "train_size": 0.7,
  "val_size": 0.15,
  "test_size": 0.15,
  "split_strategy": "sample_stratified",
  "speaker_column": "session_id",
  "random_state": 42,
  "num_workers": 0,
  "use_class_weights": true,
  "early_stopping_patience": 15,
  "monitor_metric": "macro_f1",
  "lr_scheduler": "reduce_on_plateau",
  "scheduler_monitor_metric": "macro_f1",
  "scheduler_factor": 0.5,
  "scheduler_patience": 6,
  "scheduler_min_lr": 1e-06,
  "device": null,
  "verbose": true
}